 "components": {
  "task_instruction": "You are a precise text classifier. Read the input text and assign it to exactly one of the categories defined below.",
  "label::alarm_query": "",
  "label::alarm_set": "",
  "label::calendar_query": "",
  "label::calendar_remove": "",
  "label::calendar_set": "",
  "label::cooking_recipe": "",
  "label::datetime_query": "",
  "label::email_query": "",
  "label::email_sendemail": "",
  "label::general_quirky": "General_quirky includes open-ended or indirect requests, musings, or conversational inputs that do not fit a fact-based or command-driven category. Use this for casual conversation (\"wake up\"), vague prompts, social icebreakers, or requests for a general overview (\"tell me about rihana\"). If unsure between general_quirky and social_post, choose general_quirky if the text is conversational or seeks engagement, but social_post if it is a stand-alone, topic-oriented phrase or headline.",
  "label::iot_hue_lightoff": "",
  "label::lists_createoradd": "",
  "label::lists_query": "",
  "label::lists_remove": "",
  "label::music_query": "",
  "label::news_query": "",
  "label::play_audiobook": "",
  "label::play_music": "",
  "label::play_podcasts": "",
  "label::play_radio": "",
  "label::qa_currency": "",
  "label::qa_definition": "",
  "label::qa_factoid": "qa_factoid covers direct questions seeking a single, specific fact, such as a date, number, place, or name (\"When was Einstein born?\", \"What is the capital of France?\"). Do not use this label for general overviews or open-ended questions about people or topics—instead use general_quirky for those. If the input is asking for a definition or explanation, use qa_definition instead.",
  "label::qa_stock": "",
  "label::recommendation_events": "",
  "label::recommendation_locations": "",
  "label::social_post": "Social_post covers short, topic-oriented phrases or headlines that resemble social network posts, content tags, or bulletin board messages (e.g., \"consumer desk\", \"mixed or fake products in market\"). Use this label when the input reads more like a label, slogan, or post title rather than a conversational utterance or an open-ended question. If unsure between social_post and general_quirky, choose social_post if the input is concise, impersonal, and could be found as a post or tag in a social media or forum context.",
  "label::takeaway_order": "",
  "label::transport_query": "",
  "label::weather_query": "",
  "boundary_rules": ""
