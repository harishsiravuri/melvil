 "components": {
  "task_instruction": "You are a precise text classifier. Read the input text and assign it to exactly one of the categories defined below.",
  "label::alarm_query": "",
  "label::alarm_set": "Alarm_set is for setting an alarm or alert to go off at a specific time, usually for waking up or a simple time-based notification without any event or task details. If deciding between alarm_set and calendar_set, use alarm_set for wake-up alarms or generic time alerts not linked to calendar events or reminders.",
  "label::calendar_query": "",
  "label::calendar_remove": "",
  "label::calendar_set": "Calendar_set is for requests to create, add, or schedule events, reminders, or appointments tied to a specific date or time. If the user wants to be reminded about an event, task, or meeting at a particular time, choose calendar_set. If deciding between calendar_set and alarm_set, use calendar_set for reminders about activities or events (not waking up or general alerts).",
  "label::cooking_recipe": "",
  "label::datetime_query": "",
  "label::email_query": "",
  "label::email_sendemail": "",
  "label::general_quirky": "General_quirky covers requests for fun, creative, or open-ended information such as jokes, stories, facts about celebrities, or commentary on entertainment topics. If a user asks for details about a celebrity, a film, or general entertainment (not a specific factual answer), classify as general_quirky. If deciding between general_quirky and qa_factoid, choose general_quirky for entertainment, pop culture, or creative/informal requests.",
  "label::iot_hue_lightoff": "",
  "label::lists_createoradd": "",
  "label::lists_query": "",
  "label::lists_remove": "",
  "label::music_query": "",
  "label::news_query": "",
  "label::play_audiobook": "",
  "label::play_music": "",
  "label::play_podcasts": "",
  "label::play_radio": "",
  "label::qa_currency": "",
  "label::qa_definition": "",
  "label::qa_factoid": "Qa_factoid covers questions seeking specific, factual answers—such as dates, numbers, places, or names related to non-entertainment topics. If the user’s query is about a concrete fact outside of pop culture or general entertainment, select qa_factoid. If deciding between qa_factoid and general_quirky, choose qa_factoid for precise fact-based questions about factual knowledge, not celebrities or entertainment.",
  "label::qa_stock": "",
  "label::recommendation_events": "",
  "label::recommendation_locations": "",
  "label::social_post": "",
  "label::takeaway_order": "",
  "label::transport_query": "",
  "label::weather_query": "",
