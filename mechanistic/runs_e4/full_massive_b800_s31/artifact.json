 "components": {
  "task_instruction": "You are a precise text classifier. Read the input text and assign it to exactly one of the categories defined below.",
  "label::alarm_query": "",
  "label::alarm_set": "Assign to this category if the text asks to set a general alarm or timer—a timed alert not tied to a calendar event or appointment (e.g., \"set an alarm in 10 minutes\", \"wake me at 7 a.m.\"). If deciding between 'alarm_set' and 'calendar_set', choose 'alarm_set' only if no event, meeting, or appointment is being referenced.",
  "label::calendar_query": "",
  "label::calendar_remove": "",
  "label::calendar_set": "Assign to this category if the text asks to create, add, or schedule an event, meeting, or reminder that is tied to a specific time or date in a calendar (e.g., meetings, appointments). Decide between 'calendar_set' and 'alarm_set' by whether the intent refers to a calendar event (calendar_set) or a generic timed alert not tied to a calendar (alarm_set). Texts mentioning reminders for events, appointments, or tasks at specific dates/times go here.",
  "label::cooking_recipe": "",
  "label::datetime_query": "",
  "label::email_query": "Assign to this category if the text asks to check, read, search, or list emails without sending, composing, or editing them (e.g., \"do I have new mail?\", \"show me Anne's last email\"). If deciding between 'email_sendemail' and 'email_query', select 'email_query' if the request is only for information about email content or status with no intent to send or modify emails.",
  "label::email_sendemail": "Assign to this category if the text requests sending, composing, editing, forwarding, or replying to an email (e.g., \"send an email\", \"change the recipient's address\", \"reply to John\"). If deciding between 'email_sendemail' and 'email_query', pick 'email_sendemail' if the user wants to perform an action that alters, creates, or sends an email.",
  "label::general_quirky": "Assign to this category if the text is a general or open-ended request, comment, or prompt that does not clearly fit any of the other specific categories—such as \"tell me about [person]\" or vague diary-like entries (\"record what happened today\"). If deciding between 'general_quirky' and 'qa_factoid', choose 'general_quirky' if the request is broad or conversational and not a direct question for a specific fact or piece of information.",
  "label::iot_hue_lightoff": "",
  "label::lists_createoradd": "",
  "label::lists_query": "",
  "label::lists_remove": "",
  "label::music_query": "Assign to this category if the text asks for information about music, such as song names, artists, album details, charts, or recommendations, without actually requesting music be played (e.g., \"who sings this song?\", \"what are the top hits?\"). If deciding between 'music_query' and 'play_music', choose 'music_query' only if there is no intent to start or control playback.",
  "label::news_query": "",
  "label::play_audiobook": "Assign to this category if the text requests starting, playing, resuming, or controlling playback of audiobooks specifically (e.g., \"resume my audiobook,\" \"play the next chapter,\" \"start Pride and Prejudice audiobook\"). If deciding between 'play_audiobook' and 'play_music', choose 'play_audiobook' when the content requested is an audiobook (spoken-word books), not music or songs.",
  "label::play_music": "Assign to this category if the text requests starting, playing, resuming, or controlling playback of music, including specific songs, genres, artists, albums, or playlists (e.g., \"play some jazz\", \"add King Crimson's first album\", \"resume music\"). If deciding between 'play_music' and 'play_audiobook', choose 'play_music' only if the user wants music (not audiobooks or spoken-word books); if both could apply, select based on whether the request mentions music or songs versus books.",
  "label::play_podcasts": "",
  "label::play_radio": "",
  "label::qa_currency": "",
  "label::qa_definition": "",
  "label::qa_factoid": "Assign to this category if the text asks a direct factual question seeking a specific piece of information (such as a fact, date, place, or numerical detail), e.g., \"When was Rihanna born?\", \"What is the population of Paris?\", or \"How tall is Mount Everest?\". If deciding between 'qa_factoid' and 'general_quirky', choose 'qa_factoid' only if the question is explicit and requests an objective fact, not a general overview or open-ended information.",
  "label::qa_stock": "",
  "label::recommendation_events": "",
  "label::recommendation_locations": "",
  "label::social_post": "",
  "label::takeaway_order": "",
  "label::transport_query": "",
  "label::weather_query": "",
  "boundary_rules": ""
 },
